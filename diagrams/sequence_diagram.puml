@startuml PaddyScan_Sequence

skinparam defaultFontSize 15
skinparam defaultFontStyle bold
skinparam defaultFontName Arial
skinparam dpi 200

skinparam sequenceArrowThickness 2
skinparam sequenceArrowFontSize 14
skinparam sequenceArrowFontStyle bold
skinparam sequenceArrowColor #E65100
skinparam SequenceMessageAlignment center

skinparam ParticipantFontSize 15
skinparam ParticipantFontStyle bold
skinparam ParticipantFontColor #1A1A1A
skinparam ParticipantBackgroundColor #FFD700
skinparam ParticipantBorderColor #B8860B
skinparam ParticipantBorderThickness 2
skinparam ParticipantPadding 5

skinparam ActorFontSize 15
skinparam ActorFontStyle bold
skinparam ActorBackgroundColor #FFD700
skinparam ActorBorderColor #B8860B

skinparam SequenceGroupFontSize 14
skinparam SequenceGroupFontStyle bold
skinparam SequenceGroupBorderThickness 2
skinparam SequenceGroupBorderColor #F57F17
skinparam SequenceGroupBodyBackgroundColor #FFF9C4

skinparam NoteBackgroundColor #FFECB3
skinparam NoteBorderColor #FFB300
skinparam NoteFontSize 14
skinparam NoteFontStyle bold

skinparam SequenceDividerFontSize 16
skinparam SequenceDividerFontStyle bold
skinparam SequenceDividerBackgroundColor #FFD700
skinparam SequenceDividerBorderColor #B8860B

skinparam BoxFontSize 16
skinparam BoxFontStyle bold
skinparam BoxBackgroundColor #FFF3E0
skinparam BoxBorderColor #F57F17

skinparam BackgroundColor #FFFDE7
skinparam RoundCorner 8
skinparam Shadowing true

title <color:#B8860B><size:28>PaddyScan</size></color>  <size:20>Sequence Diagram</size>

actor "<&person> User"            as U    #FFD700
participant "<&phone> Home Screen" as Home #FFE082
participant "<&cog> Home BLoC"     as Bloc #FFD54F
participant "<&cloud-upload> API"  as Api  #FFCA28
participant "<&server> Flask Server" as Srv #FFA000
participant "<&comment-square> AI Service" as AI #FF8F00

== App Startup ==
U -> Home : Launch App
Home -> Api : Check server connection
Api -> Srv  : GET /health
Srv --> Api : 200 OK
Api --> Home : Connected
Home --> U  : Home Tab ready

== Select & Capture Image ==
U -> Home : Tap Camera / Gallery
Home -> Bloc : PickImageEvent(source)
activate Bloc #FFD700
Bloc --> Home : Image captured & previewed
deactivate Bloc

== Select Analysis Mode ==
U -> Home : Tap Classify / Detect / Diagnose
Home -> Bloc : ChangeModeEvent(mode)
activate Bloc #FFD700
Bloc --> Home : Mode selected
deactivate Bloc

== Analyse Image ==
U -> Home : Tap "START ANALYSIS"
Home -> Bloc : AnalyzeImageEvent()
activate Bloc #FFD700
Bloc -> Api  : POST /api/{mode} { image: base64 }
Api -> Srv   : Send image + mode
activate Srv #FFA000
Srv -> Srv   : Run ML Model
Srv --> Api  : Return prediction result
deactivate Srv
Api --> Bloc : PredictionResult
Bloc --> Home : Analysis complete
deactivate Bloc

== View Results ==
Home --> U : Navigate to Result Page
note over U, Home #FFECB3
  Disease Name · Confidence Score
  Bounding Boxes · Affected Area %
  Severity Level · Top-3 Predictions
end note

== AI Treatment Recommendation ==
Home -> AI : Get treatment for disease
activate AI #FF8F00
AI --> Home : Stream recommendation text
deactivate AI
Home --> U : Display treatment advice

== Save to History ==
Home -> Home : Save scan to SharedPreferences
Home --> U   : Scan saved in History Tab

@enduml
