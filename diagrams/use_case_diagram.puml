@startuml PaddyScan_UseCase

skinparam defaultFontSize 16
skinparam defaultFontStyle bold
skinparam defaultFontName Arial
skinparam dpi 200

skinparam nodesep 30
skinparam ranksep 40
skinparam padding 6

skinparam actorStyle awesome
skinparam ActorFontSize 16
skinparam ActorFontStyle bold
skinparam ActorBackgroundColor #FFD700
skinparam ActorBorderColor #B8860B
skinparam ActorBorderThickness 2
skinparam ActorFontColor #1A1A1A

skinparam UsecaseFontSize 15
skinparam UsecaseFontStyle bold
skinparam UsecaseBackgroundColor #FFF9C4
skinparam UsecaseBorderColor #F9A825
skinparam UsecaseBorderThickness 2
skinparam UsecaseFontColor #1A1A1A

skinparam PackageFontSize 17
skinparam PackageFontStyle bold
skinparam PackageBorderColor #F57F17
skinparam PackageBorderThickness 2
skinparam PackageBackgroundColor #FFF3E0

skinparam ArrowColor #E65100
skinparam ArrowThickness 2
skinparam ArrowFontSize 13
skinparam ArrowFontStyle bold

skinparam RoundCorner 12
skinparam Shadowing true
skinparam BackgroundColor #FFFDE7

left to right direction

title <color:#B8860B><size:28>PaddyScan</size></color>  <size:20>Use Case Diagram</size>

actor "<&person>\nFarmer / User"  as User   #FFD700
actor "<&cloud-upload>\nFlask Server" as Server #FFB300
actor "<&comment-square>\nAI Service"  as AI     #FFC107

package "<&phone>  Scanning & Analysis" as P1 #FFFDE7 {
  usecase "<&camera>  Capture Image (Camera)"     as UC1
  usecase "<&image>  Select from Gallery"          as UC2
  usecase "<&check>  Classify Disease"             as UC3
  usecase "<&target>  Detect Affected Areas"       as UC4
  usecase "<&magnifying-glass>  Full Diagnosis"    as UC5
  usecase "<&bar-chart>  View Results"             as UC6
}

package "<&comment-square>  AI Elaboration" as P2 #FFFDE7 {
  usecase "<&lightbulb>  View AI Recommendation"  as UC7
  usecase "<&transfer>  Switch AI Model"           as UC8
}

package "<&list>  History" as P3 #FFFDE7 {
  usecase "<&eye>  View Scan History"              as UC9
  usecase "<&trash>  Delete Scans"                 as UC10
}

package "<&cog>  Settings" as P4 #FFFDE7 {
  usecase "<&wifi>  Configure Server IP"           as UC11
  usecase "<&moon>  Toggle Dark Mode"              as UC12
  usecase "<&globe>  Switch Language"              as UC13
  usecase "<&task>  Toggle AI Diagnosis"           as UC14
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC11
User --> UC12
User --> UC13
User --> UC14

Server --> UC3
Server --> UC4
Server --> UC5
Server --> UC11

AI --> UC7

UC3 .> UC6 : <<include>>
UC4 .> UC6 : <<include>>
UC5 .> UC6 : <<include>>
UC6 .> UC7 : <<extend>>
UC7 .> UC8 : <<extend>>

@enduml
